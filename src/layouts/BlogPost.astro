---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { articleSchema, breadcrumbSchema } from '../utils/schema';
import { SITE_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, author, tags, category, draft } =
	Astro.props;

const ogImage = heroImage ? new URL(heroImage.src, Astro.site).href : undefined;

const schemas = [
	articleSchema({
		title,
		description,
		url: new URL(Astro.url.pathname, Astro.site).href,
		publishedTime: pubDate.toISOString(),
		modifiedTime: updatedDate?.toISOString(),
		author,
		image: ogImage,
	}),
	breadcrumbSchema([
		{ name: 'Beranda', url: SITE_URL },
		{ name: 'Blog', url: `${SITE_URL}/blog/` },
		{ name: title, url: new URL(Astro.url.pathname, Astro.site).href },
	]),
];
---

<html lang="id">
	<head>
		<BaseHead
			title={title}
			description={description}
			image={ogImage}
			schemas={schemas}
			ogType="article"
			article={{
				publishedTime: pubDate.toISOString(),
				modifiedTime: updatedDate?.toISOString(),
				author,
				section: category,
				tags,
			}}
			noindex={draft}
		/>
	</head>

	<body>
		<Header />
		<main class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
			<article>
				<div class="mb-8">
					{heroImage && (
						<Image width={1020} height={510} src={heroImage} alt="" class="rounded-xl shadow-md mb-6" />
					)}
					<div class="text-center">
						<div class="text-sm text-sg-gray mb-2">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="italic"> — Diperbarui <FormattedDate date={updatedDate} /></span>
							)}
						</div>
						<h1 class="font-heading text-2xl sm:text-3xl font-bold text-sg-charcoal">{title}</h1>
						<hr class="mt-6 border-sg-gray-light" />
					</div>
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
