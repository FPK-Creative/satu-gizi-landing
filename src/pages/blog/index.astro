---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { breadcrumbSchema } from '../../utils/schema';
import { SITE_URL } from '../../consts';

const title = 'Blog Gizi — Panduan SPPG, Tips Nutrisi & Edukasi MBG | Satu Gizi';
const description =
	'Artikel dan panduan seputar gizi, manajemen SPPG MBG, tips nutrisi, dan edukasi pangan untuk ahli gizi, dietisien, dan pengelola dapur satuan pelayanan di Indonesia.';

const schemas = [
	breadcrumbSchema([
		{ name: 'Beranda', url: SITE_URL },
		{ name: 'Blog', url: `${SITE_URL}/blog/` },
	]),
];

const posts = (await getCollection('blog'))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={title} description={description} schemas={schemas} />
	</head>
	<body>
		<Header />
		<main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
			<h1 class="font-heading text-3xl font-bold text-sg-charcoal mb-8">Blog Gizi</h1>
			<section>
				<ul class="grid sm:grid-cols-2 gap-6 list-none p-0 m-0">
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`} class="block group">
								{post.data.heroImage && (
									<Image width={720} height={360} src={post.data.heroImage} alt="" class="rounded-xl mb-3 group-hover:shadow-lg transition-shadow" />
								)}
								<h4 class="font-heading font-semibold text-sg-charcoal group-hover:text-sg-green transition-colors">
									{post.data.title}
								</h4>
								<p class="text-sm text-sg-gray mt-1">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
