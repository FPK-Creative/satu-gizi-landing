---
import LandingLayout from '../layouts/LandingLayout.astro';
import { breadcrumbSchema } from '../utils/schema';
import { SITE_URL } from '../consts';

const schemas = [
	breadcrumbSchema([
		{ name: 'Beranda', url: SITE_URL },
		{ name: 'Tentang Kami', url: `${SITE_URL}/about/` },
	]),
];

const title = 'Tentang Satu Gizi — Platform Gizi Indonesia';
const description =
	'Satu Gizi adalah platform edukasi gizi komprehensif yang menghubungkan akademisi, praktisi kesehatan, dan masyarakat dalam ekosistem pengetahuan gizi terpadu. Kenali misi, visi, dan nilai-nilai kami.';
---

<LandingLayout title={title} description={description} schemas={schemas}>
	<section class="py-16 sm:py-20 lg:py-24 bg-white">
		<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="text-center mb-12" data-reveal>
				<h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-sg-charcoal mb-4">
					Tentang Satu Gizi
				</h1>
				<p class="text-lg text-sg-gray max-w-2xl mx-auto">
					Gizi yang Tepat, Dimulai dari Satu Langkah
				</p>
			</div>

			<div class="prose prose-lg max-w-none" data-reveal>
				<div class="bg-sg-cream rounded-2xl p-8 sm:p-10 mb-10">
					<h2 class="font-heading text-2xl font-bold text-sg-green-dark mb-4">Siapa Kami?</h2>
					<p class="text-sg-charcoal leading-relaxed">
						<strong>Satu Gizi</strong> adalah platform edukasi gizi komprehensif yang
						menghubungkan akademisi, praktisi kesehatan, dan masyarakat dalam satu ekosistem
						pengetahuan gizi terpadu di Indonesia. Kami menyatukan ilmu gizi berbasis bukti
						dengan praktik kehidupan sehari-hari untuk menciptakan Indonesia yang lebih sehat.
					</p>
				</div>

				<div class="grid sm:grid-cols-2 gap-8 mb-10">
					<div class="bg-sg-green-light/40 rounded-2xl p-6 sm:p-8">
						<div class="w-12 h-12 bg-sg-green rounded-xl flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
							</svg>
						</div>
						<h3 class="font-heading text-xl font-bold text-sg-green-dark mb-2">Visi</h3>
						<p class="text-sg-charcoal">
							Menjadi platform rujukan utama edukasi gizi di Indonesia yang menghubungkan
							akademisi, praktisi kesehatan, dan masyarakat dalam satu ekosistem pengetahuan
							gizi terpadu.
						</p>
					</div>
					<div class="bg-sg-orange-light/40 rounded-2xl p-6 sm:p-8">
						<div class="w-12 h-12 bg-sg-orange rounded-xl flex items-center justify-center mb-4">
							<svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
							</svg>
						</div>
						<h3 class="font-heading text-xl font-bold text-sg-orange-dark mb-2">Misi</h3>
						<p class="text-sg-charcoal">
							Menyatukan ilmu gizi berbasis bukti dengan praktik kehidupan sehari-hari untuk
							menciptakan Indonesia yang lebih sehat melalui edukasi gizi yang komprehensif dan
							mudah dipahami.
						</p>
					</div>
				</div>

				<h2 class="font-heading text-2xl font-bold text-sg-charcoal mb-6">Nilai-Nilai Kami</h2>
				<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
					<div class="border border-sg-gray-light rounded-xl p-5">
						<h3 class="font-heading font-semibold text-sg-green-dark mb-1">Kesatuan</h3>
						<p class="text-sm text-sg-gray">Menyatukan berbagai perspektif gizi dalam satu platform.</p>
					</div>
					<div class="border border-sg-gray-light rounded-xl p-5">
						<h3 class="font-heading font-semibold text-sg-green-dark mb-1">Berbasis Bukti</h3>
						<p class="text-sm text-sg-gray">Informasi kredibel dan ilmiah dari jurnal dan penelitian terkini.</p>
					</div>
					<div class="border border-sg-gray-light rounded-xl p-5">
						<h3 class="font-heading font-semibold text-sg-green-dark mb-1">Mudah Diakses</h3>
						<p class="text-sm text-sg-gray">Bahasa yang dipahami semua kalangan tanpa mengurangi substansi.</p>
					</div>
					<div class="border border-sg-gray-light rounded-xl p-5">
						<h3 class="font-heading font-semibold text-sg-green-dark mb-1">Kolaboratif</h3>
						<p class="text-sm text-sg-gray">Mendorong kerja sama interprofesional antara tenaga kesehatan.</p>
					</div>
					<div class="border border-sg-gray-light rounded-xl p-5">
						<h3 class="font-heading font-semibold text-sg-green-dark mb-1">Terpercaya</h3>
						<p class="text-sm text-sg-gray">Sumber informasi yang dapat diandalkan untuk keputusan kesehatan.</p>
					</div>
				</div>

				<h2 class="font-heading text-2xl font-bold text-sg-charcoal mb-6">Apa yang Kami Tawarkan</h2>
				<div class="space-y-4 mb-10">
					<div class="flex gap-4 items-start">
						<div class="shrink-0 w-8 h-8 bg-sg-green rounded-lg flex items-center justify-center text-white font-bold text-sm mt-0.5">1</div>
						<div>
							<h3 class="font-heading font-semibold text-sg-charcoal">Fitur MBG Gratis untuk SPPG</h3>
							<p class="text-sg-gray text-sm">Perencanaan menu mingguan, analisis AKG, RAB otomatis, dan laporan BGN — gratis selamanya untuk Satuan Pelayanan Pangan.</p>
						</div>
					</div>
					<div class="flex gap-4 items-start">
						<div class="shrink-0 w-8 h-8 bg-sg-green rounded-lg flex items-center justify-center text-white font-bold text-sm mt-0.5">2</div>
						<div>
							<h3 class="font-heading font-semibold text-sg-charcoal">Kalkulator Klinis Pro</h3>
							<p class="text-sg-gray text-sm">FNCA, SQ-FFQ, Z-score WHO, kebutuhan energi DM/CKD — tools klinis berbasis referensi resmi untuk ahli gizi dan peneliti.</p>
						</div>
					</div>
					<div class="flex gap-4 items-start">
						<div class="shrink-0 w-8 h-8 bg-sg-green rounded-lg flex items-center justify-center text-white font-bold text-sm mt-0.5">3</div>
						<div>
							<h3 class="font-heading font-semibold text-sg-charcoal">Database Pangan Indonesia</h3>
							<p class="text-sg-gray text-sm">Menggunakan TKPI 2020 (Tabel Komposisi Pangan Indonesia) dari Kementerian Kesehatan RI sebagai database utama.</p>
						</div>
					</div>
				</div>

				<div class="bg-sg-green text-white rounded-2xl p-8 sm:p-10 text-center" data-reveal>
					<h2 class="font-heading text-2xl font-bold mb-3">Siap Memulai?</h2>
					<p class="text-white/90 mb-6 max-w-lg mx-auto">
						Bergabung dengan ribuan pengelola SPPG dan ahli gizi yang sudah menggunakan Satu Gizi.
					</p>
					<a
						href="/#harga"
						class="inline-block bg-white text-sg-green font-semibold px-8 py-3 rounded-xl hover:bg-sg-cream transition-colors"
					>
						Mulai Gratis Sekarang
					</a>
				</div>
			</div>
		</div>
	</section>
</LandingLayout>
