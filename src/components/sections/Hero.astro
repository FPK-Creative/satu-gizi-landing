---
---

<section class="relative overflow-hidden bg-gradient-to-br from-sg-green-dark via-sg-green to-sg-fresh text-white">
	<!-- Subtle grid pattern overlay -->
	<div class="absolute inset-0 opacity-10" style="background-image: url(&quot;data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.4'%3E%3Cpath d='M0 0h1v40H0zM40 0h1v40h-1z'/%3E%3Cpath d='M0 0h40v1H0zM0 40h40v1H0z'/%3E%3C/g%3E%3C/svg%3E&quot;);"></div>

	<div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20 lg:py-28">
		<div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
			<!-- Left: Text -->
			<div data-reveal>
				<h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-bold leading-tight tracking-tight">
					Satu Platform untuk<br />
					Semua Kebutuhan Gizi
				</h1>
				<p class="mt-5 text-base sm:text-lg text-white/85 leading-relaxed max-w-xl">
					Kelola program MBG dengan mudah — dari perencanaan menu, analisis nilai gizi, hingga laporan BGN. Gratis selamanya untuk SPPG. Ditambah kalkulator gizi klinis profesional untuk ahli gizi dan peneliti.
				</p>

				<!-- CTA Buttons -->
				<div class="mt-8 flex flex-col sm:flex-row gap-3">
					<a href="/register" class="inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold bg-white text-sg-green-dark rounded-lg hover:bg-sg-green-light transition-colors shadow-lg">
						Daftar SPPG — Gratis Selamanya &rarr;
					</a>
					<a href="#kalkulator" class="inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold border-2 border-white/60 text-white rounded-lg hover:bg-white/10 transition-colors">
						Coba Kalkulator Gratis
					</a>
				</div>

				<!-- Trust Badges -->
				<div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-white/75">
					<span class="flex items-center gap-1.5">
						<svg class="w-4 h-4 text-sg-green-light" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
						Tanpa kartu kredit
					</span>
					<span class="flex items-center gap-1.5">
						<svg class="w-4 h-4 text-sg-green-light" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
						Database TKPI 2020
					</span>
					<span class="flex items-center gap-1.5">
						<svg class="w-4 h-4 text-sg-green-light" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
						Sesuai standar BGN
					</span>
				</div>
			</div>

			<!-- Right: Dashboard Mockup -->
			<div data-reveal class="relative">
				<div class="bg-white/10 backdrop-blur-sm rounded-xl border border-white/20 p-6 shadow-2xl">
					<!-- Mock top bar -->
					<div class="flex items-center gap-2 mb-4">
						<div class="w-3 h-3 rounded-full bg-red-400/60"></div>
						<div class="w-3 h-3 rounded-full bg-yellow-400/60"></div>
						<div class="w-3 h-3 rounded-full bg-green-400/60"></div>
						<span class="ml-3 text-xs text-white/50 font-mono">meal-plan.sppg.satugizi.id</span>
					</div>
					<!-- Mock content -->
					<div class="space-y-3">
						<div class="flex items-center justify-between bg-white/10 rounded-lg p-3">
							<div>
								<p class="text-sm font-semibold">Nasi Goreng Ayam</p>
								<p class="text-xs text-white/60">Kategori: Makan Siang</p>
							</div>
							<span class="text-xs bg-green-400/20 text-green-200 px-2 py-1 rounded-full">AKG Terpenuhi</span>
						</div>
						<div class="flex items-center justify-between bg-white/10 rounded-lg p-3">
							<div>
								<p class="text-sm font-semibold">Sayur Bayam Bening</p>
								<p class="text-xs text-white/60">Kategori: Lauk Sayur</p>
							</div>
							<span class="text-xs bg-yellow-400/20 text-yellow-200 px-2 py-1 rounded-full">Vitamin A Kurang</span>
						</div>
						<div class="flex items-center justify-between bg-white/10 rounded-lg p-3">
							<div>
								<p class="text-sm font-semibold">Buah Potong</p>
								<p class="text-xs text-white/60">Kategori: Snack</p>
							</div>
							<span class="text-xs bg-green-400/20 text-green-200 px-2 py-1 rounded-full">AKG Terpenuhi</span>
						</div>
						<!-- AKG Progress bars -->
						<div class="pt-2 space-y-2">
							<div class="flex items-center gap-3">
								<span class="text-xs text-white/70 w-16">Energi</span>
								<div class="flex-1 h-2 bg-white/10 rounded-full overflow-hidden">
									<div class="h-full bg-green-400 rounded-full" style="width: 92%"></div>
								</div>
								<span class="text-xs text-white/70 font-mono">92%</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="text-xs text-white/70 w-16">Protein</span>
								<div class="flex-1 h-2 bg-white/10 rounded-full overflow-hidden">
									<div class="h-full bg-green-400 rounded-full" style="width: 105%"></div>
								</div>
								<span class="text-xs text-white/70 font-mono">105%</span>
							</div>
							<div class="flex items-center gap-3">
								<span class="text-xs text-white/70 w-16">Vitamin A</span>
								<div class="flex-1 h-2 bg-white/10 rounded-full overflow-hidden">
									<div class="h-full bg-yellow-400 rounded-full" style="width: 65%"></div>
								</div>
								<span class="text-xs text-white/70 font-mono">65%</span>
							</div>
						</div>
					</div>
				</div>
				<!-- Subtle glow -->
				<div class="absolute -inset-4 bg-sg-green/20 rounded-2xl blur-xl -z-10"></div>
			</div>
		</div>

		<!-- Micro-copy -->
		<p class="mt-10 text-center text-sm text-white/60">
			Digunakan oleh SPPG di Jawa Tengah, DIY, dan Jawa Timur
		</p>
	</div>
</section>
