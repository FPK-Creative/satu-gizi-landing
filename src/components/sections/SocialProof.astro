---
const stats = [
	{ number: '2.847', label: 'Bahan Makanan TKPI' },
	{ number: '9', label: 'Kategori Penerima MBG' },
	{ number: '21', label: 'Parameter Nilai Gizi' },
	{ number: '8+', label: 'Kalkulator Klinis' },
	{ number: '100%', label: 'Gratis untuk SPPG' },
];
---

<section class="bg-sg-green-dark py-10 sm:py-14">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-8 text-center">
			{stats.map((stat) => (
				<div data-reveal>
					<p class="text-2xl sm:text-3xl lg:text-4xl font-mono font-bold text-white">
						{stat.number}
					</p>
					<p class="mt-1 text-xs sm:text-sm text-white/70">
						{stat.label}
					</p>
				</div>
			))}
		</div>
	</div>
</section>
