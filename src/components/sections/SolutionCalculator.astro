---
const categories = [
	{
		title: 'Assessment Tools',
		calculators: [
			{ icon: '🔬', name: 'NUSA', description: 'Analisis komposisi zat gizi dari daftar makanan', badge: 'Pro', badgeColor: 'bg-sg-blue/10 text-sg-blue' },
			{ icon: '📋', name: 'SQ-FFQ', description: 'Estimasi asupan habitual dari frekuensi konsumsi', badge: 'Pro', badgeColor: 'bg-sg-blue/10 text-sg-blue' },
		],
	},
	{
		title: 'Dewasa Sehat & Populasi Umum',
		calculators: [
			{ icon: '👤', name: 'Dewasa Sehat', description: 'BMI, BMR, TDEE, distribusi makronutrien', badge: 'Gratis + Pro', badgeColor: 'bg-sg-green-light text-sg-green' },
			{ icon: '🤰', name: 'Maternal', description: 'Kebutuhan gizi ibu hamil & menyusui, KEK', badge: 'Gratis + Pro', badgeColor: 'bg-sg-green-light text-sg-green' },
			{ icon: '👶', name: 'Balita', description: 'Z-score WHO, kurva pertumbuhan, LiLA', badge: 'Gratis + Pro', badgeColor: 'bg-sg-green-light text-sg-green' },
			{ icon: '🧒', name: 'Anak & Remaja', description: 'Status gizi WHO 2007, kebutuhan energi anak', badge: 'Gratis + Pro', badgeColor: 'bg-sg-green-light text-sg-green' },
		],
	},
	{
		title: 'Kalkulator Penyakit',
		calculators: [
			{ icon: '🫘', name: 'CKD', description: 'Kebutuhan gizi pasien ginjal kronis, eGFR', badge: 'Gratis + Pro', badgeColor: 'bg-sg-green-light text-sg-green' },
			{ icon: '🩺', name: 'Diabetes', description: 'Kebutuhan energi DM, distribusi karbo, HbA1c', badge: 'Gratis + Pro', badgeColor: 'bg-sg-green-light text-sg-green' },
			{ icon: '🫀', name: 'Hipertensi', description: 'Diet DASH, klasifikasi tekanan darah', badge: 'Gratis + Pro', badgeColor: 'bg-sg-green-light text-sg-green' },
			{ icon: '🎗️', name: 'Onkologi', description: 'PG-SGA & penilaian gizi kanker', badge: 'Pro', badgeColor: 'bg-sg-blue/10 text-sg-blue' },
			{ icon: '🔪', name: 'Bedah', description: 'Nutrisi perioperatif', badge: 'Pro', badgeColor: 'bg-sg-blue/10 text-sg-blue' },
			{ icon: '🦶', name: 'Gout', description: 'Diet rendah purin, kadar asam urat', badge: 'Gratis + Pro', badgeColor: 'bg-sg-green-light text-sg-green' },
			{ icon: '🩸', name: 'Dislipidemia', description: 'Profil lipid, diet kolesterol & lemak', badge: 'Gratis + Pro', badgeColor: 'bg-sg-green-light text-sg-green' },
		],
	},
	{
		title: 'Skrining & Penilaian Gizi Klinis',
		calculators: [
			{ icon: '📊', name: 'Malnutrisi', description: 'MNA, MUST, NRS-2002', badge: 'Gratis + Pro', badgeColor: 'bg-sg-green-light text-sg-green' },
			{ icon: '💉', name: 'Enteral & Parenteral', description: 'TPN, perhitungan nutrisi parenteral', badge: 'Pro', badgeColor: 'bg-sg-blue/10 text-sg-blue' },
			{ icon: '🔍', name: 'Skrining SNST & MST', description: 'Skrining gizi rumah sakit', badge: 'Gratis + Pro', badgeColor: 'bg-sg-green-light text-sg-green' },
		],
	},
];
---

<section id="kalkulator" class="py-16 sm:py-20 lg:py-24 bg-sg-charcoal">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<!-- Badge + Headline -->
		<div class="text-center mb-12" data-reveal>
			<span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-sg-orange/10 text-sg-orange text-xs font-semibold mb-4">
				💰 Kalkulator Pro — Untuk Ahli Gizi & Peneliti
			</span>
			<h2 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-bold text-white">
				Kalkulator Gizi Klinis Profesional
			</h2>
			<p class="mt-3 text-base text-white/60 max-w-2xl mx-auto">
				Tools yang biasa dipakai berpencar-pencar, kini hadir dalam satu platform dengan riwayat sesi tersimpan.
			</p>
		</div>

		<!-- Calculator Categories -->
		<div class="space-y-10">
			{categories.map((cat) => (
				<div data-reveal>
					<h3 class="text-xs font-semibold uppercase tracking-wider text-white/40 mb-4">{cat.title}</h3>
					<div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
						{cat.calculators.map((calc) => (
							<div class="bg-white/5 border border-white/10 rounded-xl p-5 hover:bg-white/10 transition-colors">
								<div class="text-2xl mb-3">{calc.icon}</div>
								<h4 class="font-heading font-semibold text-white text-sm mb-1">{calc.name}</h4>
								<p class="text-xs text-white/50 leading-relaxed mb-3">{calc.description}</p>
								<span class={`inline-block text-xs font-medium px-2 py-0.5 rounded-full ${calc.badgeColor}`}>
									{calc.badge}
								</span>
							</div>
						))}
					</div>
				</div>
			))}
		</div>

		<!-- CTA -->
		<div class="mt-10 text-center" data-reveal>
			<a href="/calculators" class="inline-flex items-center gap-1 text-sm font-semibold text-sg-orange hover:text-sg-yellow transition-colors">
				Lihat Semua Kalkulator &rarr;
			</a>
		</div>
	</div>
</section>
