---

<section class="py-16 sm:py-20 lg:py-24 bg-sg-green-dark text-white relative overflow-hidden">
	<!-- Decorative circles -->
	<div class="absolute top-0 right-0 w-64 h-64 bg-sg-green/10 rounded-full -translate-y-1/2 translate-x-1/3"></div>
	<div class="absolute bottom-0 left-0 w-48 h-48 bg-sg-green/10 rounded-full translate-y-1/3 -translate-x-1/4"></div>

	<div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
		<div data-reveal>
			<h2 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-bold leading-tight">
				Mulai Sekarang — Gratis untuk SPPG
			</h2>
			<p class="mt-4 text-base sm:text-lg text-white/75 max-w-xl mx-auto">
				Bergabunglah dengan SPPG yang sudah mengelola program MBG lebih efisien dengan Satu Gizi.
			</p>

			<!-- CTA Buttons -->
			<div class="mt-8 flex flex-col sm:flex-row justify-center gap-3">
				<a href="/register" class="inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold bg-white text-sg-green-dark rounded-lg hover:bg-sg-green-light transition-colors shadow-lg">
					Daftar SPPG Gratis &rarr;
				</a>
				<a href="/demo" class="inline-flex items-center justify-center px-6 py-3.5 text-base font-semibold border-2 border-white/40 text-white rounded-lg hover:bg-white/10 transition-colors">
					Jadwalkan Demo
				</a>
			</div>

			<!-- Trust elements -->
			<div class="mt-8 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-white/65">
				<span class="flex items-center gap-1.5">
					<svg class="w-4 h-4 text-sg-green-light" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
					Setup dalam 10 menit
				</span>
				<span class="flex items-center gap-1.5">
					<svg class="w-4 h-4 text-sg-green-light" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
					Tidak perlu kartu kredit
				</span>
				<span class="flex items-center gap-1.5">
					<svg class="w-4 h-4 text-sg-green-light" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
					Data bisa diekspor kapan saja
				</span>
			</div>
		</div>
	</div>
</section>
